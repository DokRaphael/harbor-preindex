APP_NAME=harbor-preindex
ORCHESTRATOR_NODE=localhost
LOG_LEVEL=INFO

HARBOR_ROOT=./data/storage-root
HARBOR_DATA_DIR=./data/runtime
HARBOR_LOG_DIR=./data/runtime/logs

# Optional overrides. Leave empty to derive paths from HARBOR_DATA_DIR.
RESULTS_DIR=
SQLITE_PATH=
QDRANT_MODE=local
QDRANT_PATH=./data/runtime/qdrant
QDRANT_COLLECTION=projects

TOP_K=5
SAMPLE_FILES_PER_DIRECTORY=8
MAX_TEXT_SNIPPET_CHARS=1200
MAX_PROFILE_CHARS=4000
SUPPORTED_EXTENSIONS=.txt,.md,.pdf,.py,.js,.ts,.tsx,.json,.yaml,.yml,.toml,.sh,.bash,.zsh,.sql,.html,.css,.xml,.ini,.conf
EXCLUDED_PATH_SEGMENTS=build,dist,node_modules,.git,__pycache__,example,examples,test,tests,testdata,assets,static,libraries

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
EMBEDDING_MODEL=embeddinggemma
LLM_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_MAX_RETRIES=2
EMBEDDING_BATCH_SIZE=16

AUTO_ACCEPT_SCORE=0.90
AUTO_ACCEPT_SCORE_GAP=0.12
LLM_MAX_CANDIDATES=5
